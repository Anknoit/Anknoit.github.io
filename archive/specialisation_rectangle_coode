              <line x1="183" y1="93"  x2="183" y2="217" stroke="#1c1c1c" stroke-width="1.5"/>
              <!-- Branch tick marks -->
              <line x1="179" y1="93"  x2="187" y2="93"  stroke="#2a2a2a" stroke-width="1.5"/>
              <line x1="179" y1="155" x2="187" y2="155" stroke="#2a2a2a" stroke-width="1.5"/>
              <line x1="179" y1="217" x2="187" y2="217" stroke="#2a2a2a" stroke-width="1.5"/>

              <!-- Junction → AMF (N2) -->
              <line x1="183" y1="93"  x2="213" y2="93"  stroke="#1c1c1c" stroke-width="1.5"/>
              <line x1="183" y1="93"  x2="213" y2="93"  stroke="rgba(255,255,255,0.1)" stroke-width="1" class="nf"/>
              <text x="198" y="84" text-anchor="middle" font-family="IBM Plex Sans,sans-serif" font-size="6.5" fill="rgba(255,255,255,0.2)">N2</text>

              <!-- Junction → SMF (N3) -->
              <line x1="183" y1="155" x2="213" y2="155" stroke="#1c1c1c" stroke-width="1.5"/>
