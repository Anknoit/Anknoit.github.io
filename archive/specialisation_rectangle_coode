              <line x1="271" y1="155" x2="344" y2="155" stroke="#1a050e" stroke-width="2.5"/>
              <line x1="271" y1="155" x2="344" y2="155" stroke="rgba(176,16,48,0.58)" stroke-width="2" class="nfr" marker-end="url(#arrR)"/>
              <text x="307" y="145" text-anchor="middle" font-family="IBM Plex Sans,sans-serif" font-size="7.5" font-weight="600" fill="rgba(176,16,48,0.72)">Gx / Gy</text>

              <!-- UPF → HSS/UDM -->
              <line x1="271" y1="217" x2="344" y2="217" stroke="#1a050e" stroke-width="1.5"/>
              <line x1="271" y1="217" x2="344" y2="217" stroke="rgba(176,16,48,0.22)" stroke-width="1" class="nfr"/>

              <!-- AAA ↓ PCRF (vertical Gy) -->
              <line x1="375" y1="105" x2="375" y2="143" stroke="#1a050e" stroke-width="1.5"/>
              <line x1="375" y1="105" x2="375" y2="143" stroke="rgba(176,16,48,0.38)" stroke-width="1.5" class="nfr"/>
