              <line x1="244" y1="105" x2="244" y2="143" stroke="#242424" stroke-width="1"/>
              <line x1="244" y1="167" x2="244" y2="205" stroke="#242424" stroke-width="1"/>

              <!-- AMF → AAA (Diameter / N12) RED -->
              <line x1="271" y1="93"  x2="344" y2="93"  stroke="#1a050e" stroke-width="1.5"/>
              <line x1="271" y1="93"  x2="344" y2="93"  stroke="rgba(176,16,48,0.38)" stroke-width="1.5" class="nfr" marker-end="url(#arrR)"/>
              <text x="307" y="83" text-anchor="middle" font-family="IBM Plex Sans,sans-serif" font-size="7" fill="rgba(176,16,48,0.52)">Diameter</text>

