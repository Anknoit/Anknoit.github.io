<div class="hero-right reveal reveal-d2">
          <div class="net-diagram-wrap">
            <svg viewBox="0 0 500 310" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="5G/LTE Core Network Architecture">
              <defs>
                <style>
                  @keyframes netflow  { to { stroke-dashoffset: -24; } }
                  @keyframes netflowR { to { stroke-dashoffset: -24; } }
                  .nf  { stroke-dasharray:5 4; animation: netflow  3s linear infinite; }
                  .nfr { stroke-dasharray:5 4; animation: netflowR 1.7s linear infinite; }
                  @keyframes nodepulse { 0%,100%{opacity:0.85} 50%{opacity:1} }
                  .pulse { animation: nodepulse 2.5s ease-in-out infinite; }
                </style>
                <pattern id="bgdots" width="22" height="22" patternUnits="userSpaceOnUse">
                  <circle cx="11" cy="11" r=".6" fill="rgba(255,255,255,0.048)"/>
                </pattern>
                <filter id="redglow" x="-60%" y="-60%" width="220%" height="220%">
                  <feGaussianBlur in="SourceGraphic" stdDeviation="3" result="blur"/>
                  <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
                </filter>
                <marker id="arr" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
                  <path d="M0,0 L0,6 L6,3 z" fill="rgba(255,255,255,0.18)"/>
                </marker>
                <marker id="arrR" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
                  <path d="M0,0 L0,6 L6,3 z" fill="rgba(176,16,48,0.55)"/>
                </marker>
              </defs>

              <!-- Background -->
              <rect width="500" height="310" fill="#070707"/>
              <rect width="500" height="310" fill="url(#bgdots)"/>

              <!-- Column region fills (very subtle) -->
              <rect x="340" y="0" width="160" height="310" fill="rgba(176,16,48,0.025)"/>

              <!-- Column divider lines -->
              <line x1="175" y1="0" x2="175" y2="310" stroke="rgba(255,255,255,0.03)" stroke-width="1"/>
              <line x1="340" y1="0" x2="340" y2="310" stroke="rgba(176,16,48,0.09)" stroke-width="1"/>

              <!-- Column labels -->
              <text x="88"  y="20" text-anchor="middle" font-family="IBM Plex Sans,sans-serif" font-size="6.5" font-weight="600" fill="rgba(255,255,255,0.18)" letter-spacing="1.8">ACCESS</text>
              <text x="257" y="20" text-anchor="middle" font-family="IBM Plex Sans,sans-serif" font-size="6.5" font-weight="600" fill="rgba(255,255,255,0.18)" letter-spacing="1.8">EPC / 5G CORE</text>
              <text x="420" y="20" text-anchor="middle" font-family="IBM Plex Sans,sans-serif" font-size="6.5" font-weight="600" fill="rgba(176,16,48,0.6)" letter-spacing="1.8">SPECIALISATION</text>

              <!-- ── CONNECTIONS ── -->

              <!-- UE → gNB (Uu) -->
              <line x1="70"  y1="155" x2="100" y2="155" stroke="#1c1c1c" stroke-width="1.5"/>
              <line x1="70"  y1="155" x2="100" y2="155" stroke="rgba(255,255,255,0.18)" stroke-width="1" class="nf" marker-end="url(#arr)"/>
              <text x="85" y="147" text-anchor="middle" font-family="IBM Plex Sans,sans-serif" font-size="7" fill="rgba(255,255,255,0.22)">Uu</text>

              <!-- gNB → branch junction -->
              <line x1="158" y1="155" x2="183" y2="155" stroke="#1c1c1c" stroke-width="1.5"/>
