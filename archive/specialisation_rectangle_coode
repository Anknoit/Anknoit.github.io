              <line x1="375" y1="167" x2="375" y2="205" stroke="rgba(176,16,48,0.22)" stroke-width="1" class="nfr"/>

              <!-- PCRF → IPLMS (key output line) RED -->
              <line x1="402" y1="155" x2="428" y2="155" stroke="#1a050e" stroke-width="2.5"/>
              <line x1="402" y1="155" x2="428" y2="155" stroke="rgba(176,16,48,0.55)" stroke-width="2" class="nfr" marker-end="url(#arrR)"/>

              <!-- AAA diagonal → IPLMS top -->
              <line x1="402" y1="96"  x2="428" y2="148" stroke="#1a050e" stroke-width="1.5"/>
              <line x1="402" y1="96"  x2="428" y2="148" stroke="rgba(176,16,48,0.3)" stroke-width="1" class="nfr"/>

              <!-- UPF → Internet (data path) -->
              <line x1="271" y1="221" x2="428" y2="268" stroke="#1c1c1c" stroke-width="1.5"/>
              <line x1="271" y1="221" x2="428" y2="268" stroke="rgba(255,255,255,0.1)" stroke-width="1" class="nf" marker-end="url(#arr)"/>
              <text x="354" y="254" text-anchor="middle" font-family="IBM Plex Sans,sans-serif" font-size="6.5" fill="rgba(255,255,255,0.18)">N6</text>

              <!-- ── NODES ── (all 58×24 rx=3, translate cx-29, cy-12) -->

              <!-- UE: cx=41 cy=155 -->
              <g transform="translate(12,143)">
                <rect width="58" height="24" rx="3" fill="#0e0e0e" stroke="#252525" stroke-width="1"/>
                <text x="29" y="16" text-anchor="middle" font-family="IBM Plex Sans,sans-serif" font-size="9" font-weight="500" fill="rgba(255,255,255,0.62)">UE</text>
              </g>

              <!-- gNB: cx=130 cy=155 -->
              <g transform="translate(100,143)">
                <rect width="58" height="24" rx="3" fill="#0e0e0e" stroke="#252525" stroke-width="1"/>
                <text x="29" y="16" text-anchor="middle" font-family="IBM Plex Sans,sans-serif" font-size="8" font-weight="500" fill="rgba(255,255,255,0.62)">gNB / RAN</text>
              </g>

              <!-- AMF: cx=244 cy=93 -->
              <g transform="translate(215,81)">
                <rect width="58" height="24" rx="3" fill="#111" stroke="#222" stroke-width="1"/>
                <text x="29" y="16" text-anchor="middle" font-family="IBM Plex Sans,sans-serif" font-size="9" font-weight="500" fill="rgba(255,255,255,0.62)">AMF</text>
              </g>

              <!-- SMF: cx=244 cy=155 -->
              <g transform="translate(215,143)">
                <rect width="58" height="24" rx="3" fill="#111" stroke="#222" stroke-width="1"/>
                <text x="29" y="16" text-anchor="middle" font-family="IBM Plex Sans,sans-serif" font-size="9" font-weight="500" fill="rgba(255,255,255,0.62)">SMF</text>
              </g>

              <!-- UPF: cx=244 cy=217 -->
              <g transform="translate(215,205)">
                <rect width="58" height="24" rx="3" fill="#111" stroke="#222" stroke-width="1"/>
                <text x="29" y="16" text-anchor="middle" font-family="IBM Plex Sans,sans-serif" font-size="9" font-weight="500" fill="rgba(255,255,255,0.62)">UPF</text>
              </g>

              <!-- AAA: cx=375 cy=93 — RED -->
              <g transform="translate(346,81)" filter="url(#redglow)" class="pulse">
                <rect width="58" height="24" rx="3" fill="#6b0b1e" stroke="#b01030" stroke-width="1.5"/>
                <text x="29" y="16" text-anchor="middle" font-family="IBM Plex Sans,sans-serif" font-size="9" font-weight="700" fill="#fff">AAA</text>
              </g>

              <!-- PCRF: cx=375 cy=155 — RED -->
              <g transform="translate(346,143)" filter="url(#redglow)" class="pulse">
                <rect width="58" height="24" rx="3" fill="#6b0b1e" stroke="#b01030" stroke-width="1.5"/>
                <text x="29" y="16" text-anchor="middle" font-family="IBM Plex Sans,sans-serif" font-size="9" font-weight="700" fill="#fff">PCRF</text>
              </g>

              <!-- HSS/UDM: cx=375 cy=217 -->
              <g transform="translate(346,205)">
                <rect width="58" height="24" rx="3" fill="#111" stroke="#222" stroke-width="1"/>
                <text x="29" y="16" text-anchor="middle" font-family="IBM Plex Sans,sans-serif" font-size="8" font-weight="500" fill="rgba(255,255,255,0.62)">HSS / UDM</text>
              </g>

              <!-- IPLMS: cx=459 cy=155 — RED BRIGHTEST -->
              <g transform="translate(430,143)" filter="url(#redglow)" class="pulse">
                <rect width="58" height="24" rx="3" fill="#b01030" stroke="#d01842" stroke-width="1.5"/>
                <text x="29" y="16" text-anchor="middle" font-family="IBM Plex Sans,sans-serif" font-size="9" font-weight="700" fill="#fff">IPLMS</text>
              </g>

              <!-- Internet: cx=459 cy=268 — dashed border -->
              <g transform="translate(430,256)">
                <rect width="58" height="24" rx="3" fill="#0a0a0a" stroke="#282828" stroke-width="1" stroke-dasharray="3 2"/>
                <text x="29" y="16" text-anchor="middle" font-family="IBM Plex Sans,sans-serif" font-size="8" font-weight="400" fill="rgba(255,255,255,0.35)">Internet</text>
              </g>

              <!-- ── BOTTOM LEGEND ── -->
              <line x1="32" y1="295" x2="52" y2="295" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"/>
              <text x="57" y="299" font-family="IBM Plex Sans,sans-serif" font-size="6.5" fill="rgba(255,255,255,0.22)">Data path</text>
              <line x1="130" y1="295" x2="150" y2="295" stroke="rgba(176,16,48,0.55)" stroke-width="2"/>
              <text x="155" y="299" font-family="IBM Plex Sans,sans-serif" font-size="6.5" fill="rgba(176,16,48,0.55)">DIAMETER / AAA</text>
              <rect x="274" y="290" width="10" height="10" rx="2" fill="#b01030"/>
              <text x="289" y="299" font-family="IBM Plex Sans,sans-serif" font-size="6.5" fill="rgba(176,16,48,0.55)">Specialisation</text>

              <!-- Diagram title -->
              <text x="500" y="299" text-anchor="end" font-family="IBM Plex Sans,sans-serif" font-size="6" fill="rgba(255,255,255,0.12)" letter-spacing="1">3GPP EPC / 5GC REFERENCE</text>
            </svg>
          </div>
