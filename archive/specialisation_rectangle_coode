              <line x1="183" y1="217" x2="213" y2="217" stroke="#1c1c1c" stroke-width="1.5"/>
              <line x1="183" y1="217" x2="213" y2="217" stroke="rgba(255,255,255,0.08)" stroke-width="1" class="nf"/>

